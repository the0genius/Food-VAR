{
  "expo": {
    "name": "FoodVAR",
    "slug": "foodvar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foodvar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8F5E9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foodvar.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FoodVAR needs camera access to scan product barcodes"
      }
    },
    "android": {
      "package": "com.foodvar.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8F5E9",
        "foregroundImage": "./assets/images/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "FoodVAR needs camera access to scan product barcodes"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "foodvar",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
