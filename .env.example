# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=your-session-secret-here

# === Replit Auto-Set (do not set manually in Replit) ===
# PORT=5000
# REPLIT_DEV_DOMAIN=...
# REPLIT_DOMAINS=...
# EXPO_PUBLIC_DOMAIN=...

# === AI Integrations (via Replit Integrations) ===
AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# === Error Monitoring ===
# Sentry DSN for error reporting (org: foodvar, project: react-native)
# Disabled in dev mode automatically. Get from Sentry project settings.
EXPO_PUBLIC_SENTRY_DSN=https://your-key@o12345.ingest.de.sentry.io/12345

# === CORS ===
# Comma-separated list of additional allowed origins (beyond Replit auto-detected ones)
# ALLOWED_ORIGINS=https://example.com,https://staging.example.com

# === Feature Flags ===
# Controls whether AI-generated dietary advice is enabled.
# When OFF, the scoring engine still works but returns deterministic explanations only.
# Default: true
ENABLE_AI_ADVICE=true

# Controls whether the chat feature (conversations with AI) is available.
# SAFETY: Chat has no system prompt guardrails. Disable for production until hardened.
# Default: false
ENABLE_CHAT=false

# Controls whether the image generation endpoint is available.
# SAFETY: No content moderation. Disable for production.
# Default: false
ENABLE_IMAGE_GENERATION=false

# Controls whether unverified (pending moderation) products appear in public search,
# popular lists, and barcode lookups for non-contributors.
# SAFETY: Unverified products may contain incorrect allergen data.
# Default: false
EXPOSE_UNVERIFIED_PRODUCTS=false

# Controls whether trusted contributors can bypass moderation queues.
# SAFETY: Requires a distinct audited role system, not just isPro.
# Default: false
ENABLE_TRUSTED_CONTRIBUTOR_BYPASS=false

# === Logging ===
# LOG_LEVEL=info  # Options: debug, info, warn, error
